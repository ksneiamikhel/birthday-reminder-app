# GitHub Configuration
VITE_GITHUB_TOKEN=your_personal_access_token_here
VITE_GITHUB_USERNAME=your_github_username
VITE_GITHUB_REPO=your_username/birthday-reminder-data

# Claude API (for gift suggestions)
# ANTHROPIC_API_KEY=sk-xxx... (add later when building gift suggestions)

# Telegram (for notifications)
# TELEGRAM_BOT_TOKEN=xxx... (add later when setting up Telegram)
# VITE_APP_URL=https://your-vercel-app.vercel.app (add when deploying to Vercel)
