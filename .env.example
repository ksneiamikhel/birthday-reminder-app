# GitHub Configuration (Frontend - user credentials)
VITE_GITHUB_TOKEN=your_personal_access_token_here
VITE_GITHUB_USERNAME=your_github_username
VITE_GITHUB_REPO=your_username/birthday-reminder-data

# GitHub Token (Vercel - server side for user registry)
GITHUB_TOKEN=your_personal_access_token_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WELCOME_MESSAGE=✅ Birthday Reminder Connected!\n\nI will notify you 7 days before each birthday. 🎁
TELEGRAM_BIRTHDAY_MESSAGE=🎂 {name}'s birthday is in 7 days!\n📅 {date}\n🎁 Check the app for gift ideas!

# Security (for cron endpoint)
CRON_SECRET=your_random_secret_here

# Claude API (optional - for gift suggestions)
# ANTHROPIC_API_KEY=sk-ant-xxx...

# App URL
VITE_APP_URL=https://your-vercel-app.vercel.app
